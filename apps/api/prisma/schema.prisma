generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
}

enum VendorVerificationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum QuotationRequestStatus {
  SENT
  VIEWED
  CLARIFICATION_REQUESTED
  QUOTED
  ACCEPTED
  DECLINED
  CLOSED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  CLARIFICATION_REQUESTED
  REVISED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum BookingStatus {
  AWAITING_VENDOR_CONFIRMATION
  CONFIRMED
  DEPOSIT_PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  STRIPE_CHECKOUT
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  QUOTATION_REQUEST_RECEIVED
  QUOTATION_SENT
  QUOTATION_ACCEPTED
  PAYMENT_SUBMITTED
  PAYMENT_VERIFIED
  PAYMENT_REJECTED
  VENDOR_APPROVED
  VENDOR_REJECTED
  COMPLAINT_CREATED
  COMPLAINT_MESSAGE_RECEIVED
  COMPLAINT_STATUS_CHANGED
  SYSTEM
}

enum ExpenseStatus {
  PLANNED
  PAID
  CANCELLED
}

enum EventTaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum GuestStatus {
  NOT_INVITED
  INVITED
  CONFIRMED
  DECLINED
  MAYBE
}

enum MoodBoardCategory {
  DECORATION
  FLOWERS
  OUTFIT
  CAKE
  INVITATION
  PHOTOGRAPHY
  VENUE
  TABLE_SETTING
  COLOR_PALETTE
  ENTERTAINMENT
  OTHER
}

enum EventDocumentCategory {
  CONTRACT
  QUOTATION
  INVOICE
  PAYMENT_RECEIPT
  SCHEDULE
  GUEST_LIST
  MENU
  FLOOR_PLAN
  PERMIT
  VENDOR_DOCUMENT
  REFERENCE
  OTHER
}

enum ReviewModerationActionType {
  HIDDEN
  RESTORED
}

enum ComplaintType {
  BOOKING
  PAYMENT
  REVIEW
  QUOTATION
  USER_CONDUCT
  PLATFORM
  OTHER
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_CUSTOMER_RESPONSE
  AWAITING_VENDOR_RESPONSE
  UNDER_INVESTIGATION
  RESOLVED
  DISMISSED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintActionType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  RESOLVED
  DISMISSED
  CLOSED
  REOPENED
}

model User {
  id                        String                   @id @default(cuid())
  email                     String                   @unique
  passwordHash              String
  firstName                 String
  lastName                  String
  role                      UserRole
  status                    AccountStatus            @default(ACTIVE)
  customer                  CustomerProfile?
  vendor                    VendorProfile?
  createdEvents             Event[]                  @relation("EventOwner")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  customerReviews           Review[]
  moderatedReviews          Review[]                 @relation("ReviewCurrentModerator")
  reviewModerationActions   ReviewModerationAction[] @relation("ReviewModerationActor")
  submittedPayments         Payment[]                @relation("PaymentSubmitter")
  reviewedPayments          Payment[]                @relation("PaymentReviewer")
  notifications             Notification[]
  submittedComplaints       Complaint[]              @relation("ComplaintComplainant")
  receivedComplaints        Complaint[]              @relation("ComplaintRespondent")
  assignedComplaints        Complaint[]              @relation("ComplaintAssignedAdmin")
  complaintMessages         ComplaintMessage[]
  performedComplaintActions ComplaintAction[]        @relation("ComplaintActionActor")
}

model CustomerProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  phone  String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VendorProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  businessName       String
  slug               String                    @unique
  description        String?
  contactPhone       String?
  website            String?
  baseLocation       String?
  serviceAreas       String[]                  @default([])
  verificationStatus VendorVerificationStatus  @default(DRAFT)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  rejectionReason    String?
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories         VendorCategory[]
  packages           ServicePackage[]
  quotationRequests  QuotationRequest[]
  bookings           Booking[]
  availabilityBlocks VendorAvailabilityBlock[]
  reviews            Review[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  moodBoardItems     MoodBoardItem[]
  eventDocuments     EventDocument[]
}

model ServiceCategory {
  id       String           @id @default(cuid())
  name     String           @unique
  slug     String           @unique
  vendors  VendorCategory[]
  packages ServicePackage[]
}

model VendorCategory {
  vendorId   String
  categoryId String
  vendor     VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([vendorId, categoryId])
}

model ServicePackage {
  id                String             @id @default(cuid())
  vendorId          String
  categoryId        String
  title             String
  description       String?
  basePrice         Decimal?           @db.Decimal(12, 2)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  vendor            VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category          ServiceCategory    @relation(fields: [categoryId], references: [id])
  quotationRequests QuotationRequest[]
  reviews           Review[]

  @@index([vendorId, isActive])
}

model Event {
  id                String                @id @default(cuid())
  ownerId           String
  name              String
  eventType         String
  eventDate         DateTime
  location          String
  guestCount        Int?
  plannedBudget     Decimal?              @db.Decimal(12, 2)
  theme             String?
  requirements      String?
  status            EventStatus           @default(DRAFT)
  owner             User                  @relation("EventOwner", fields: [ownerId], references: [id])
  quotationRequests QuotationRequest[]
  bookings          Booking[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  budgetCategories  EventBudgetCategory[]
  expenses          Expense[]
  tasks             EventTask[]
  guests            Guest[]
  moodBoardItems    MoodBoardItem[]
  documents         EventDocument[]

  @@index([ownerId, eventDate])
}

model EventBudgetCategory {
  id              String    @id @default(cuid())
  eventId         String
  name            String
  allocatedAmount Decimal   @db.Decimal(12, 2)
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  expenses        Expense[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([eventId, name])
  @@index([eventId, createdAt])
}

model Expense {
  id               String               @id @default(cuid())
  eventId          String
  budgetCategoryId String?
  title            String
  amount           Decimal              @db.Decimal(12, 2)
  status           ExpenseStatus        @default(PLANNED)
  expenseDate      DateTime?
  dueDate          DateTime?
  notes            String?
  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  budgetCategory   EventBudgetCategory? @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([eventId, status])
  @@index([budgetCategoryId])
  @@index([eventId, dueDate])
}

model EventTask {
  id          String            @id @default(cuid())
  eventId     String
  title       String
  description String?
  status      EventTaskStatus   @default(TODO)
  priority    EventTaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([eventId, status])
  @@index([eventId, priority])
  @@index([eventId, dueDate])
}

model Guest {
  id                  String           @id @default(cuid())
  eventId             String
  firstName           String
  lastName            String
  email               String?
  phone               String?
  groupName           String?
  status              GuestStatus      @default(NOT_INVITED)
  partySize           Int              @default(1)
  mealPreference      String?
  dietaryRequirements String?
  notes               String?
  invitedAt           DateTime?
  respondedAt         DateTime?
  event               Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  invitation          EventInvitation?

  @@unique([eventId, email])
  @@index([eventId, status])
  @@index([eventId, groupName])
  @@index([eventId, lastName, firstName])
}

model QuotationRequest {
  id            String                 @id @default(cuid())
  eventId       String
  vendorId      String
  packageId     String?
  requirements  String
  responseDueAt DateTime?
  status        QuotationRequestStatus @default(SENT)
  event         Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor        VendorProfile          @relation(fields: [vendorId], references: [id])
  package       ServicePackage?        @relation(fields: [packageId], references: [id])
  quotations    Quotation[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  complaints    Complaint[]

  @@index([eventId, status])
  @@index([vendorId, status])
}

model Quotation {
  id                 String           @id @default(cuid())
  quotationRequestId String
  version            Int
  status             QuotationStatus  @default(DRAFT)
  proposedPrice      Decimal          @db.Decimal(12, 2)
  depositAmount      Decimal?         @db.Decimal(12, 2)
  inclusions         String
  exclusions         String?
  terms              String?
  expiresAt          DateTime?
  quotationRequest   QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  booking            Booking?
  createdAt          DateTime         @default(now())

  @@unique([quotationRequestId, version])
}

model Booking {
  id                         String        @id @default(cuid())
  eventId                    String
  vendorId                   String
  acceptedQuotationId        String        @unique
  agreedCost                 Decimal       @db.Decimal(12, 2)
  serviceStart               DateTime
  serviceEnd                 DateTime?
  status                     BookingStatus @default(AWAITING_VENDOR_CONFIRMATION)
  vendorResponseNote         String?
  vendorRespondedAt          DateTime?
  customerCancellationReason String?
  customerCancelledAt        DateTime?
  vendorCancellationReason   String?
  vendorCancelledAt          DateTime?
  vendorCompletedAt          DateTime?
  event                      Event         @relation(fields: [eventId], references: [id])
  vendor                     VendorProfile @relation(fields: [vendorId], references: [id])
  acceptedQuotation          Quotation     @relation(fields: [acceptedQuotationId], references: [id])
  payments                   Payment[]
  review                     Review?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  complaints                 Complaint[]

  @@index([vendorId, status, createdAt])
  @@index([vendorId, serviceStart, serviceEnd])
}

model VendorAvailabilityBlock {
  id        String        @id @default(cuid())
  vendorId  String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([vendorId, startsAt, endsAt])
  @@index([vendorId, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  submittedById   String
  reviewedById    String?
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  referenceNumber String
  reviewedAt      DateTime?
  rejectionReason String?
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  submittedBy     User          @relation("PaymentSubmitter", fields: [submittedById], references: [id])
  reviewedBy      User?         @relation("PaymentReviewer", fields: [reviewedById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  complaints      Complaint[]

  @@index([bookingId, status])
  @@index([status, createdAt])
  @@index([submittedById, createdAt])
  @@index([reviewedById, reviewedAt])
}

model Review {
  id                  String  @id @default(cuid())
  bookingId           String  @unique
  customerId          String
  vendorId            String
  packageId           String?
  overallRating       Int
  serviceRating       Int?
  communicationRating Int?
  comment             String?

  isHidden         Boolean   @default(false)
  moderationReason String?
  moderatedAt      DateTime?
  moderatedById    String?

  booking           Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer          User                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor            VendorProfile            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  package           ServicePackage?          @relation(fields: [packageId], references: [id], onDelete: SetNull)
  moderatedBy       User?                    @relation("ReviewCurrentModerator", fields: [moderatedById], references: [id], onDelete: SetNull)
  moderationActions ReviewModerationAction[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  complaints Complaint[]

  @@index([customerId, createdAt])
  @@index([vendorId, overallRating])
  @@index([vendorId, isHidden, createdAt])
  @@index([packageId, overallRating])
  @@index([isHidden, createdAt])
  @@index([moderatedById, moderatedAt])
}

model ReviewModerationAction {
  id          String                     @id @default(cuid())
  reviewId    String
  moderatorId String?
  action      ReviewModerationActionType
  reason      String

  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  moderator User?  @relation("ReviewModerationActor", fields: [moderatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([reviewId, createdAt])
  @@index([moderatorId, createdAt])
  @@index([action, createdAt])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  readAt      DateTime?
  entityType  String?
  entityId    String?
  metadata    Json?
  recipient   User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, createdAt])
  @@index([entityType, entityId])
}

model EventInvitation {
  id         String    @id @default(cuid())
  guestId    String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([revokedAt])
}

model MoodBoardItem {
  id            String            @id @default(cuid())
  eventId       String
  vendorId      String?
  title         String
  description   String?
  category      MoodBoardCategory @default(OTHER)
  imageUrl      String?
  imagePublicId String?
  sourceUrl     String?
  colorTags     String[]          @default([])
  event         Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor        VendorProfile?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([eventId, category])
  @@index([eventId, createdAt])
  @@index([vendorId])
}

model EventDocument {
  id          String                @id @default(cuid())
  eventId     String
  vendorId    String?
  title       String
  description String?
  category    EventDocumentCategory @default(OTHER)
  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor      VendorProfile?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  files       EventDocumentFile[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([eventId, category])
  @@index([eventId, createdAt])
  @@index([vendorId])
}

model EventDocumentFile {
  id           String        @id @default(cuid())
  documentId   String
  fileUrl      String
  filePublicId String        @unique
  originalName String
  mimeType     String
  fileSize     Int
  document     EventDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([documentId, createdAt])
  @@index([mimeType])
}

model Complaint {
  id                 String            @id @default(cuid())
  complainantId      String
  respondentId       String?
  assignedAdminId    String?
  type               ComplaintType
  subject            String
  description        String
  status             ComplaintStatus   @default(OPEN)
  priority           ComplaintPriority @default(MEDIUM)
  bookingId          String?
  paymentId          String?
  reviewId           String?
  quotationRequestId String?
  resolutionSummary  String?
  resolvedAt         DateTime?
  closedAt           DateTime?

  complainant      User               @relation("ComplaintComplainant", fields: [complainantId], references: [id])
  respondent       User?              @relation("ComplaintRespondent", fields: [respondentId], references: [id], onDelete: SetNull)
  assignedAdmin    User?              @relation("ComplaintAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  booking          Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payment          Payment?           @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  review           Review?            @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  quotationRequest QuotationRequest?  @relation(fields: [quotationRequestId], references: [id], onDelete: SetNull)
  messages         ComplaintMessage[]
  actions          ComplaintAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([complainantId, status, createdAt])
  @@index([respondentId, status, createdAt])
  @@index([assignedAdminId, status, priority])
  @@index([status, priority, createdAt])
  @@index([type, createdAt])
  @@index([bookingId])
  @@index([paymentId])
  @@index([reviewId])
  @@index([quotationRequestId])
}

model ComplaintMessage {
  id          String  @id @default(cuid())
  complaintId String
  authorId    String
  body        String
  isInternal  Boolean @default(false)

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([complaintId, createdAt])
  @@index([authorId, createdAt])
  @@index([complaintId, isInternal, createdAt])
}

model ComplaintAction {
  id            String              @id @default(cuid())
  complaintId   String
  performedById String?
  action        ComplaintActionType
  reason        String?
  metadata      Json?

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  performedBy User?     @relation("ComplaintActionActor", fields: [performedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([complaintId, createdAt])
  @@index([performedById, createdAt])
  @@index([action, createdAt])
}
