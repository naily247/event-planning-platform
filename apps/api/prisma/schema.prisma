generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
}

enum VendorVerificationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum QuotationRequestStatus {
  SENT
  VIEWED
  CLARIFICATION_REQUESTED
  QUOTED
  DECLINED
  CLOSED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  CLARIFICATION_REQUESTED
  REVISED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum BookingStatus {
  AWAITING_VENDOR_CONFIRMATION
  CONFIRMED
  DEPOSIT_PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole
  status        AccountStatus    @default(ACTIVE)
  customer      CustomerProfile?
  vendor        VendorProfile?
  createdEvents Event[]          @relation("EventOwner")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model CustomerProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  phone  String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VendorProfile {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  businessName       String
  slug               String                   @unique
  description        String?
  contactPhone       String?
  website            String?
  baseLocation       String?
  serviceAreas       String[]                 @default([])
  verificationStatus VendorVerificationStatus @default(DRAFT)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  rejectionReason    String?
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories         VendorCategory[]
  packages           ServicePackage[]
  quotationRequests  QuotationRequest[]
  bookings           Booking[]
  reviews            Review[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}

model ServiceCategory {
  id       String           @id @default(cuid())
  name     String           @unique
  slug     String           @unique
  vendors  VendorCategory[]
  packages ServicePackage[]
}

model VendorCategory {
  vendorId   String
  categoryId String
  vendor     VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([vendorId, categoryId])
}

model ServicePackage {
  id                String             @id @default(cuid())
  vendorId          String
  categoryId        String
  title             String
  description       String?
  basePrice         Decimal?           @db.Decimal(12, 2)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  vendor            VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category          ServiceCategory    @relation(fields: [categoryId], references: [id])
  quotationRequests QuotationRequest[]

  @@index([vendorId, isActive])
}

model Event {
  id                String             @id @default(cuid())
  ownerId           String
  name              String
  eventType         String
  eventDate         DateTime
  location          String
  guestCount        Int?
  plannedBudget     Decimal?           @db.Decimal(12, 2)
  theme             String?
  requirements      String?
  status            EventStatus        @default(DRAFT)
  owner             User               @relation("EventOwner", fields: [ownerId], references: [id])
  quotationRequests QuotationRequest[]
  bookings          Booking[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([ownerId, eventDate])
}

model QuotationRequest {
  id            String                 @id @default(cuid())
  eventId       String
  vendorId      String
  packageId     String?
  requirements  String
  responseDueAt DateTime?
  status        QuotationRequestStatus @default(SENT)
  event         Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor        VendorProfile          @relation(fields: [vendorId], references: [id])
  package       ServicePackage?        @relation(fields: [packageId], references: [id])
  quotations    Quotation[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([eventId, status])
  @@index([vendorId, status])
}

model Quotation {
  id                 String           @id @default(cuid())
  quotationRequestId String
  version            Int
  status             QuotationStatus  @default(DRAFT)
  proposedPrice      Decimal          @db.Decimal(12, 2)
  depositAmount      Decimal?         @db.Decimal(12, 2)
  inclusions         String
  exclusions         String?
  terms              String?
  expiresAt          DateTime?
  quotationRequest   QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  booking            Booking?
  createdAt          DateTime         @default(now())

  @@unique([quotationRequestId, version])
}

model Booking {
  id                  String        @id @default(cuid())
  eventId             String
  vendorId            String
  acceptedQuotationId String        @unique
  agreedCost          Decimal       @db.Decimal(12, 2)
  serviceStart        DateTime
  serviceEnd          DateTime?
  status              BookingStatus @default(AWAITING_VENDOR_CONFIRMATION)
  event               Event         @relation(fields: [eventId], references: [id])
  vendor              VendorProfile @relation(fields: [vendorId], references: [id])
  acceptedQuotation   Quotation     @relation(fields: [acceptedQuotationId], references: [id])
  payments            Payment[]
  review              Review?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([vendorId, serviceStart, serviceEnd])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(PENDING)
  dueAt           DateTime?
  paidAt          DateTime?
  method          String?
  referenceNumber String?
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([bookingId, status])
}

model Review {
  id                  String        @id @default(cuid())
  bookingId           String        @unique
  vendorId            String
  overallRating       Int
  serviceRating       Int?
  communicationRating Int?
  comment             String?
  booking             Booking       @relation(fields: [bookingId], references: [id])
  vendor              VendorProfile @relation(fields: [vendorId], references: [id])
  createdAt           DateTime      @default(now())

  @@index([vendorId, overallRating])
}
